generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GeneratedContent {
  id              String   @id @default(cuid())
  articleId       String
  articleTitle    String
  status          String
  caption         String
  hashtags        Json
  carouselSlides  Json
  slideImageUrls  Json
  videoScript     String
  videoUrl        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
